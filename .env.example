# ==============================================================================
# Kirana Commerce Environment Configuration Template
# ==============================================================================
# Architecture Rule: 
# Every variable here must be validated by @kirana/config Zod schemas.
# Do NOT place production secrets in this file.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Application Configuration
# ------------------------------------------------------------------------------
# The canonical URL of the application. Used for absolute links and SEO.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# 2. Feature Flags
# ------------------------------------------------------------------------------
# Controls whether the application is in maintenance mode.
# Accepts: "active", "off"
NEXT_PUBLIC_MAINTENANCE_MODE="off"

# ------------------------------------------------------------------------------
# Note: Further categories (Database, Auth, Storage, Payments, etc.) will be 
# added here in future phases as required by the architecture.
# ------------------------------------------------------------------------------
